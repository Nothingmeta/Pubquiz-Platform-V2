{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["cypress", "node"],
    "typeRoots": ["node_modules/@types"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["cypress/**/*.ts", "cypress/**/*.tsx"]
}