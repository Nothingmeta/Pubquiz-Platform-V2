@model Pubquiz_Platform_V2.ViewModels.LobbyListViewModel
@{
    ViewData["Title"] = "Quiz Lobbies";
}

<div class="container mt-5">
    @if (User.IsInRole("quizmaster") && Model.AvailableQuizzes.Any())
    {
        <form method="post" asp-action="CreateLobby" asp-controller="Quiz" class="mb-4 d-flex align-items-end gap-2">
            <select name="quizId" class="form-select" style="max-width: 250px;" required>
                <option value="">Kies een quiz...</option>
                @foreach (var quiz in Model.AvailableQuizzes)
                {
                    <option value="@quiz.Id">@quiz.QuizName</option>
                }
            </select>
            <button type="submit" class="btn btn-success">Start Quiz</button>
        </form>
    }
    <h2>Beschikbare Quiz Lobbies</h2>
    <form method="get" asp-page="/Quiz/Lobby">
        <div class="input-group mb-3" style="max-width: 400px;">
            <input type="text" class="form-control" name="lobbyCode" placeholder="Voer lobbycode in..." required />
            <button class="btn btn-primary" type="submit">Zoek &amp; Join</button>
        </div>
    </form>

    @if (Model.Lobbies.Any())
    {
        <ul class="list-group mb-4" style="max-width: 600px;">
            @foreach (var lobby in Model.Lobbies)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <strong>@lobby.QuizName</strong> <br />
                        <small>Quizmaster: @lobby.QuizMasterName</small>
                    </div>
                    <a class="btn btn-success" href="/Quiz/Lobby?lobbyCode=@lobby.LobbyCode">Join</a>
                </li>
            }
        </ul>
    }
    else
    {
        <div class="alert alert-info">Geen Quizzes beschikbaar</div>
    }
</div>
