@model Pubquiz_Platform_V2.ViewModels.EnableTwoFactorViewModel

@{
    ViewData["Title"] = "Enable Two-Factor Authentication";
}

<h2>@ViewData["Title"]</h2>

<p>Scan the QR with your authenticator app (Google Authenticator, Authy, etc.) or enter the key manually.</p>

<div>
    <img style="max-width:300px; max-height:300px;" src="@Model.QrCodeDataUri" alt="QR code for authenticator" />
</div>

<div>
    <p><strong>Manual entry key:</strong> <code>@Model.ManualEntryKey</code></p>
</div>

<form method="post" asp-action="EnableTwoFactor">
    <div class="form-group">
        <label for="code">Enter the verification code from your app</label>
        <input class="form-control" id="code" name="code" />
    </div>
    <button type="submit" class="btn btn-primary">Verify and Enable</button>
    <a class="btn btn-secondary" asp-action="Index" asp-controller="Home">Cancel</a>
</form>

@if (!string.IsNullOrEmpty(ViewBag.Error))
{
    <div class="text-danger">@ViewBag.Error</div>
}
