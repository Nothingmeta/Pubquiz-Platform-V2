@model Pubquiz_Platform_V2.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Registreren";
}

<div class="container d-flex flex-column align-items-center logo">
    <img src="../../images/PubquizPlatform.png" alt="Pubquiz Logo" width="200" />
</div>
<div class="auth-container">
    <h2>Registreren</h2>

    <form method="post" class="auth-form">
        @Html.AntiForgeryToken()
        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" type="password" />
            <span asp-validation-for="Password" class="field-validation"></span>
        </div>

        <div class="form-group">
            <label asp-for="Role"></label>
            <select asp-for="Role" id="roleSelect">
                <option value="">Selecteer rol...</option>
                <option value="speler">Speler</option>
                <option value="quizmaster">Quizmaster</option>
            </select>
            <span asp-validation-for="Role" class="field-validation"></span>

            <role-info for="roleSelect"></role-info>
        </div>

        <button type="submit" class="btn-primary">
            Account aanmaken
        </button>
    </form>

    <p class="auth-link">
        Heb je al een account?
        <a href="/Auth/Login">Inloggen</a>
    </p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script type="module" src="~/js/components/role-info.js"></script>
}
