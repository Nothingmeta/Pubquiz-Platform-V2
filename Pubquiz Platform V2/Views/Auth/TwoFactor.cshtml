@model Pubquiz_Platform_V2.ViewModels.TwoFactorVerifyViewModel

@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="d-flex justify-content-center mt-5">
    <div class="card p-4 shadow-sm" style="max-width:420px; width:100%;">
        <div class="text-center mb-3">
            <img src="~/images/PubquizPlatform.png" alt="Pubquiz Logo" width="150" class="mx-auto d-block" />
        </div>

        <h4 class="text-center mb-3">@ViewData["Title"]</h4>

        <p class="text-center mb-3">Enter the 6-digit code from your authenticator app or a recovery code.</p>

        <form method="post" asp-action="TwoFactor" class="mb-0">
            <div class="mb-3">
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Verify</button>
                <a class="btn btn-outline-secondary" asp-action="Login">Cancel</a>
            </div>
        </form>

        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="text-danger mt-3">@ViewBag.Error</div>
        }
    </div>
</div>