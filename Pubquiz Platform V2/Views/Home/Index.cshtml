@{
    ViewData["Title"] = "Home Page";
}

<div class="container d-flex flex-column align-items-center" style="min-height: 100vh;">
    <!-- Hamburger menu -->
    <div class="w-100 d-flex justify-content-start mb-3">
        <div class="dropdown">
            <button class="btn btn-outline-secondary" type="button" id="dropdownMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-list"></i>
            </button>
            <ul class="dropdown-menu" aria-labelledby="dropdownMenuButton">
                <li><a class="dropdown-item" href="/">Home</a></li>
                <li><a class="dropdown-item" href="/Quiz/Manage">Quiz beheer</a></li>
                <li><a class="dropdown-item" href="/Account/Profile">Profiel</a></li>
            </ul>
        </div>
        <span class="ms-3 align-self-center fw-bold">Pubquiz Platform</span>
    </div>
    <img src="../../images/PubquizPlatform.png" alt="Pubquiz Logo" class="mb-4" style="width: 200px; height: auto;">
    <h2 class="mb-4">Welkom</h2>

    <div class="d-flex flex-column gap-3 w-100" style="max-width: 300px;">
        <a class="btn btn-primary" href="/Quiz/LobbyOverview">Start quiz</a>
        @if (User.IsInRole("quizmaster"))
        {
            <a class="btn btn-secondary" href="/Quiz/Manage">Beheer quizzen</a>
        }
        <form method="post" action="/Auth/Logout" class="mt-4">
            <button type="submit" class="btn btn-outline-danger w-100">Log uit</button>
        </form>
    </div>
</div>
