# Docker environment configuration for Pubquiz Platform V2
# Copy this file to .env and adjust values as needed

# ASP.NET Core environment (Development, Staging, Production)
ASPNETCORE_ENVIRONMENT=Development

# Application port
APP_PORT=5000

# Logging level
LOGGING_LEVEL=Information

# Database settings (volume mounted to /app/data)
DATABASE_PATH=/app/data/Pubquiz.sqlite

# Data Protection keys path (volume mounted to /app/keys)
DATA_PROTECTION_PATH=/app/keys

# Container names
APP_CONTAINER_NAME=pubquiz-platform
DB_SETUP_CONTAINER_NAME=pubquiz-db-setup

# Volume names
DATA_VOLUME_NAME=pubquiz-data
KEYS_VOLUME_NAME=pubquiz-keys
